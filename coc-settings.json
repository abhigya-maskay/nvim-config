{
	"languageserver": {
		"ocaml": {
			"command": "ocaml-language-server",
			"args": [
				"--stdio"
			],
			"filetypes": [
				"ocaml",
				"reason"
			]
		},
		"haskell": {
			"command": "hie-wrapper",
			"rootPatterns": [
				".stack.yaml",
				".cabal.config",
				"package.yaml"
			],
			"filetypes": [
				"hs",
				"lhs",
				"haskell"
			],
			"initializationOptions": {
				"languageServerHaskell": {
					"hlintOn": true
				}
			}
		},
		"reason": {
			"command": "~/ocaml/reason-react/rls-linux/reason-language-server",
			"filetypes": [
				"reason",
				"re"
			]
		}
	}
}
