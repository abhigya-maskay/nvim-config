{
	"languageserver": {
		"haskell": {
			"command": "hie-wrapper",
			"rootPatterns": [
				".stack.yaml",
				".cabal.config",
				"package.yaml"
			],
			"filetypes": [
				"hs",
				"lhs",
				"haskell"
			],
			"initializationOptions": {
				"languageServerHaskell": {
					"hlintOn": true
				}
			}
		},
		"reason": {
			"command": "~/ocaml/rls-linux/reason-language-server",
			"filetypes": [
				"reason",
				"re"
			]
		},
		"clojure-lsp": {
		  "command": "bash",
		  "args": ["-c", "clojure-lsp"],
		  "filetypes": ["clojure"],
		  "rootPatterns": ["project.clj"],
		  "additionalSchemes": ["jar", "zipfile"],
		  "trace.server": "verbose",
		  "initializationOptions": {
		  }
		}
	}
}
